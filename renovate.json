{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "nix": { "enabled": true },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["containers/.*\\.nix$"],
      "matchStrings": [
        "image\\s*=\\s*\"docker\\.io/(?<depName>[\\w.-]+/[\\w./-]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://registry-1.docker.io"
    },
    {
      "customType": "regex",
      "fileMatch": ["containers/.*\\.nix$"],
      "matchStrings": [
        "image\\s*=\\s*\"ghcr\\.io/(?<depName>[\\w.-]+/[\\w./-]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://ghcr.io"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackagePatterns": [".*"],
      "versioning": "semver"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["nipar44/predbat_addon"],
      "versionCompatibility": "^(?<compatibility>.*)-(?<version>.*)$",
      "versioning": "semver"
    }
  ]
}
