{
  "ignition": {
    "version": "3.4.0"
  },
  "passwd": {
    "users": [
      {
        "groups": [
          "wheel"
        ],
        "name": "core",
        "sshAuthorizedKeys": [
          "ssh-ed25519 AA..."
        ]
      },
      {
        "name": "hass",
        "sshAuthorizedKeys": [
          "ssh-ed25519 AA..."
        ]
      }
    ]
  },
  "storage": {
    "directories": [
      {
        "path": "/etc/ucore-autorebase",
        "mode": 492
      }
    ],
    "disks": [
      {
        "device": "/dev/sda",
        "partitions": [
          {
            "label": "boot",
            "number": 3,
            "sizeMiB": 2048,
            "wipePartitionEntry": true
          },
          {
            "label": "root",
            "number": 4,
            "sizeMiB": 0,
            "wipePartitionEntry": true
          }
        ]
      }
    ],
    "files": [
      {
        "overwrite": true,
        "path": "/etc/hostname",
        "contents": {
          "compression": "",
          "source": "data:,bmax.homelab.bpinto.com"
        },
        "mode": 420
      },
      {
        "path": "/etc/NetworkManager/system-connections/wifi-iot.nmconnection",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,H4sIAAAAAAAC/1SPTWvDMAxA7/oVgZ0NY4ydqkGhG8uppW4po4RiHKUVqT+w5YX8++Gtlxz1eHpCZxu8JyscfAfc48QDKw4CMkf6m8AUCQ8LJRUC9kJpMJaUN45wuseX/AxwrnYHLvSE7IdksqRipSSCnLnHldbt5r15ao67zfrw0Ry+Wv3YUplsSSxzV6/dlLlfMUTyMNKs3NUJTtGomEeIecTV9/a4v5zaz/ayW2t92u5rdlnl+PPagSO5hR7rB//sbcl+AwAA//8WKGYl/gAAAA=="
        },
        "mode": 384
      },
      {
        "path": "/etc/dbus-1/system.d/bluetooth-any-user.conf",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 420
      },
      {
        "path": "/etc/selinux/homeassistant-bluetooth.pp",
        "contents": {
          "source": "data:text/plain;base64,"
        },
        "mode": 420
      }
    ],
    "filesystems": [
      {
        "device": "/dev/disk/by-partlabel/boot",
        "format": "ext4",
        "label": "boot",
        "wipeFilesystem": true
      },
      {
        "device": "/dev/disk/by-partlabel/root",
        "format": "xfs",
        "label": "root",
        "wipeFilesystem": true
      }
    ],
    "links": [
      {
        "overwrite": true,
        "path": "/etc/localtime",
        "target": "/usr/share/zoneinfo/Europe/Lisbon"
      }
    ]
  },
  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=uCore autorebase to unsigned OCI and reboot\nConditionPathExists=!/etc/ucore-autorebase/unverified\nConditionPathExists=!/etc/ucore-autorebase/signed\nAfter=network-online.target\nWants=network-online.target\n[Service]\nType=oneshot\nStandardOutput=journal+console\nExecStart=/usr/bin/rpm-ostree rebase --bypass-driver ostree-unverified-registry:ghcr.io/bpinto/homelab-ucore:latest\nExecStart=/usr/bin/touch /etc/ucore-autorebase/unverified\nExecStart=/usr/bin/systemctl disable ucore-unsigned-autorebase.service\nExecStart=/usr/bin/systemctl reboot\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "ucore-unsigned-autorebase.service"
      },
      {
        "contents": "[Unit]\nDescription=uCore autorebase to signed OCI and reboot\nConditionPathExists=/etc/ucore-autorebase/unverified\nConditionPathExists=!/etc/ucore-autorebase/signed\nAfter=network-online.target\nWants=network-online.target\n[Service]\nType=oneshot\nStandardOutput=journal+console\nExecStart=/usr/bin/rpm-ostree rebase --bypass-driver ostree-image-signed:docker://ghcr.io/bpinto/homelab-ucore:latest\nExecStart=/usr/bin/touch /etc/ucore-autorebase/signed\nExecStart=/usr/bin/systemctl disable ucore-signed-autorebase.service\nExecStart=/usr/bin/systemctl reboot\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "ucore-signed-autorebase.service"
      },
      {
        "contents": "[Unit]\nDescription=Install SELinux policy for Home Assistant Bluetooth\nAfter=network-online.target\n[Service]\nType=oneshot\nExecStart=/usr/sbin/semodule -i /etc/selinux/homeassistant-bluetooth.pp\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "selinux-homeassistant-bluetooth-install.service"
      }
    ]
  }
}
